{
  "_comment": "Persistent-object factory. Every object is a PixelLab 8-direction object (create-8-direction-object) sized for its type (32-256), with EXACTLY 3 fitting animations at max frames (16, v3) across all 8 directions, in the Grave Seasons style. Objects show in the PixelLab create-object tool and sync back (sync.py). world_height_m keeps them to scale vs a 64px character.",
  "style_base": "cozy painterly RPG pixel art in the exact style of Grave Seasons, a cohesive muted-but-warm seasonal palette, soft naturalistic lighting with strong ambient occlusion and gently rounded volumes, subtle selective darker-tone outlines (NOT a hard uniform black cartoon outline), rich high detail, crisp deliberate pixels, a single centered game prop on a transparent background",
  "style_version": 2,
  "_style_version": "Bump this when the look changes. Objects whose manifest records an older style_version are considered stale; run the loop with --restyle (or the workflow's restyle input) to delete and regenerate them in the new style.",
  "defaults": {
    "view": "low top-down",
    "direction": "south",
    "outline": "selective outline",
    "shading": "detailed shading",
    "detail": "highly detailed",
    "no_background": true,
    "text_guidance_scale": 8.0,
    "negative_description": "blurry, multiple objects, duplicated, cropped, text, watermark, drop shadow, background scenery, tiling, thick uniform black cartoon outline, sticker look, flat solid colors, low effort",
    "animation_image_guidance_scale": 3.0,
    "animation_text_guidance_scale": 6.0
  },
  "scale": {
    "_comment": "REALISM RULE: objects are scaled to the world by real height, so they sit correctly next to characters. A character is ~character_height_px tall (the 64px skeleton) representing character_height_m. The loop turns each object's world_height_m into world_px_height = round(world_height_m * character_height_px / character_height_m); a game renders the sprite scaled to that pixel height. So a coin (~0.22m) is tiny next to a character and an oak (~6m) towers. Every object MUST have a world_height_m (per-object, else category_height_m fallback).",
    "character_height_px": 64,
    "character_height_m": 1.7,
    "category_height_m": {
      "container": 0.8,
      "valuable": 0.25,
      "tool": 1.0,
      "nature": 1.0,
      "light": 1.0,
      "creature": 0.25,
      "misc": 0.8
    }
  },
  "budget": {
    "min_generations_remaining": 2000,
    "_comment": "Shared PixelLab pool floor (see coordination/PROTOCOL.md). The loop stops cleanly when the balance drops below this, leaving headroom for the characters and maps domains that draw from the same pool."
  },
  "targets": {
    "num_objects": 40,
    "_comment": "How many objects the loop aims to produce. It builds the explicit `catalog` first, then synthesizes further ones from `procedural` until this count is reached. Raise it to keep the loop generating open-endedly."
  },
